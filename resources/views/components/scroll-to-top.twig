<div class="fixed bottom-0 left-0 right-0 pointer-events-none" x-data="{ visible: false }"
    x-init="visible = window.scrollY >= document.getElementById('projects').offsetTop" x-show="visible" x-transition.opacity x-cloak
>
    <div class="container max-w-5xl flex justify-end items-end mx-auto py-8">
        <button title="Scroll to Top" class="flex justify-center items-center rounded-full border-2 border-zinc-500 bg-white shadow-sm font-medium text-zinc-500 cursor-pointer pointer-events-auto transition p-4 dark:bg-stone-800 dark:border-stone-400 dark:text-stone-400 dark:hover:bg-stone-700 hover:scale-110 hover:shadow"
            @click="$scrollTo(0)" @scroll.window="visible = window.scrollY >= document.getElementById('projects').offsetTop"
        >
            {{ svg('regular/arrow-up', ['fill-current', 'size-6']) }}
        </button>
    </div>
</div>
