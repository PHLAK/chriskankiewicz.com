{
    "name": "phlak/chriskankiewicz.com",
    "description": "Home page of Chris Kankiewicz",
    "type": "project",
    "license": "CC BY-NC-SA",
    "authors": [
        {
            "name": "Chris Kankiewicz",
            "email": "Chris@Kankiewicz.com"
        }
    ],
    "require": {
        "php": ">= 8.5",
        "guzzlehttp/guzzle": "^7.13",
        "illuminate/collections": "^13.18",
        "php-di/php-di": "^7.1",
        "php-di/slim-bridge": "^3.4",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15",
        "slim/twig-view": "^3.4",
        "symfony/cache": "^8.1",
        "twig/html-extra": "^3.24",
        "vlucas/phpdotenv": "^5.6",
        "webmozart/assert": "^2.4"
    },
    "require-dev": {
        "phlak/coding-standards": "^5.0",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^13.2",
        "symfony/var-dumper": "^8.1",
        "zorac/phpstan-php-di": "^1.0"
    },
    "suggest": {
        "ext-apcu": "Required to use the APCu cache driver",
        "ext-memcached": "Required to use the Memcached driver",
        "ext-redis": "Required to use the Redis cache driver"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
      "optimize-autoloader": true,
      "platform-check": true,
      "sort-packages": true
    }
}
